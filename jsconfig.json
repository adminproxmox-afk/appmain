{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "checkJs": false,
    "allowJs": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": [
    "./js/**/*.js",
    "./pages/js/**/*.js",
    "./game/**/*.js"
  ],
  "exclude": [
    "./.git",
    "./node_modules"
  ]
}
